        <mxCell id="edge_app_cloud" edge="1" parent="1" source="app_sw_label" style="endArrow=classic;html=1;rounded=0;fontSize=13;fontStyle=1;strokeWidth=2;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;strokeColor=#000000;" target="cloud_title" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&amp;lt;&amp;lt;HTTPS&amp;gt;&amp;gt;&lt;br style=&quot;&quot;&gt;API REST&lt;br style=&quot;&quot;&gt;(Billing)&lt;/font&gt;">
