        <mxCell id="edge_app_db" edge="1" parent="1" source="app_sw_label" style="endArrow=classic;html=1;rounded=0;fontSize=13;fontStyle=1;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;strokeColor=#000000;" target="db_sw_label" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&amp;lt;&amp;lt;TCP/IP&amp;gt;&amp;gt;&lt;br style=&quot;&quot;&gt;Driver BD&lt;/font&gt;">
